<header class="sticky top-0 z-100 bg-(--bg) backdrop-blur-md border-b border-(--border)">
    <div class="max-w-7xl mx-auto px-10 h-14 flex items-center justify-between">
      <div class="flex items-center gap-10">
        <a href="#" class="font-mono text-[0.7rem] text-(--fg) tracking-[0.2em] uppercase no-underline">Ascalon</a>
        <nav class="flex gap-6">
          <button class="nav-link" data-cat="Culture">Culture</button>
          <button class="nav-link" data-cat="Technology">Technology</button>
          <button class="nav-link" data-cat="Politics">Politics</button>
          <button class="nav-link" data-cat="Science">Science</button>
          <button class="nav-link" data-cat="Arts">Arts</button>
        </nav>
      </div>
      <div style="display:flex;align-items:center;gap:1rem">
        <button class="font-mono text-[0.7rem] tracking-[0.12em] uppercase border border-(--border) bg-transparent text-(--fg) px-4 py-[0.35rem] cursor-pointer transition-[border-color,color] duration-200 hover:border-(--accent) hover:text-(--accent)">Subscribe</button>
        <button class="flex md:hidden flex-col gap-1.25 bg-transparent border-none cursor-pointer p-1 group" id="hamburger" aria-label="Toggle menu">
            <span class="block w-5 h-px bg-(--fg) transition-[transform,opacity] duration-300 group-[.open]:translate-y-1.5 group-[.open]:rotate-45"></span>
            <span class="block w-5 h-px bg-(--fg) transition-[transform,opacity] duration-300 group-[.open]:opacity-0"></span>
            <span class="block w-5 h-px bg-(--fg) transition-[transform,opacity] duration-300 group-[.open]:-translate-y-1.5 group-[.open]:-rotate-45"></span>
        </button>

      </div>
    </div>
    <div class="hidden [&.open]:flex flex-col gap-3 px-10 py-4 border-t border-(--border) bg-(--bg)" id="mobileMenu">
      <button class="nav-link" data-cat="All">All</button>
      <button class="nav-link" data-cat="Culture">Culture</button>
      <button class="nav-link" data-cat="Technology">Technology</button>
      <button class="nav-link" data-cat="Politics">Politics</button>
      <button class="nav-link" data-cat="Science">Science</button>
      <button class="nav-link" data-cat="Arts">Arts</button>
    </div>
  </header>
