---
interface Props {
    category: string;
    number: string;
    title: string;
    excerpt: string;
    author: string;
    readingTime: string;
    image: string;
    imageAlt: string;
    href: string;
}
const {
    category,
    number,
    title,
    excerpt,
    author,
    readingTime,
    image,
    imageAlt,
    href,
} = Astro.props;
---
<a
    href={href}
    class="group flex flex-col border-t border-rule pt-5 text-inherit no-underline"
>
    <div class="mb-5 aspec-4/3 w-full overflow-hidden bg-neutral-900">
        <img
            src={image}
            alt={imageAlt}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duraiton-500 ease-out group-hover:scale-103"
        />
    </div>

    <div class="flex flex-1 flex-col">
        <p class="mb-3 flex items-baseline justify-between font-mono text-[0.7rem] tracking-wider">
            <span class="font-medium text-accent">{category}</span>
            <span class="text-text-muted">{number}</span>
        </p>

        <h3 class="mb-2.5 font-display text-[1.375rem] leading-tight font-semibold text-text transition-colors group-hover:text-accent">
            {title}
        </h3>

        <p class="mb-4 line-clamp-2 font-body text-[0.9rem] leading-relaxed text-text-muted">
            {excerpt}
        </p>

        <p class="mt-auto flex items-baseline justify-between font-mono text-[0.7rem] tracking-wide text-text-faint">
            <span>{author}</span>
            <span>{readingTime}</span>
        </p>
    </div>
</a>
